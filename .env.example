# ─────────────────────────────────────────────────────────────
# XeivoraMed environment configuration
# Copy to `.env` and fill in. Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# --- Mode ---
# DEMO_MODE=true  → seeded demo fixtures, demo role buttons, emergency demo
# DEMO_MODE=false → LIVE: only real database data; empty states when none.
#                   Requires DATABASE_URL + Supabase keys below.
# unset           → derived: demo when DB/Supabase are not configured
DEMO_MODE=false

# --- Database (PostgreSQL) — REQUIRED in live mode ---
# Supabase gives you both a pooled (6543) and a direct (5432) URL.
DATABASE_URL="postgresql://postgres:password@localhost:5432/xeivoramed?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/xeivoramed?schema=public"

# --- Supabase Auth — REQUIRED in live mode ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server only, never exposed

# --- App ---
NEXT_PUBLIC_APP_URL="https://xeivora.com"
NODE_ENV="development"

# --- Record encryption (AES-256-GCM) ---
# Generate: openssl rand -base64 32
RECORD_ENCRYPTION_KEY="base64-32-byte-key"

# --- Internal cron secret (protects /api/cron/*) ---
CRON_SECRET="long-random-string"

# --- Twilio (SMS + optional Voice for phone-call reminders) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM="+94XXXXXXXXX"
TWILIO_VOICE_FROM="+94XXXXXXXXX"

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v21.0"

# --- Web Push (VAPID) ---
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:ops@sehat.lk"

# --- AWS S3 (document storage) ---
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="sehat-health-records"

# --- Video consultation provider (stub — see src/lib/consult/video.ts) ---
# Choose Daily.co or Agora when wiring live video.
VIDEO_PROVIDER="stub"
DAILY_API_KEY=""

# --- Apple Wallet (Medical Passport Pass) — optional; pass signing requires these ---
APPLE_PASS_TYPE_IDENTIFIER=""
APPLE_TEAM_IDENTIFIER=""
APPLE_WALLET_CERT_PATH=""
APPLE_WALLET_KEY_PATH=""
APPLE_WALLET_KEY_PASSWORD=""

# --- Google Wallet (Medical Passport Pass) — optional; save links require these ---
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_CLASS_ID=""
GOOGLE_WALLET_SERVICE_ACCOUNT_JSON=""
